#!/bin/bash
set -euxo pipefail

dnf update -y
dnf install -y docker

systemctl enable docker
systemctl start docker

usermod -aG docker ec2-user

mkdir -p /opt/tasktracker
chown ec2-user:ec2-user /opt/tasktracker

cat >/etc/motd <<'EOF'
TaskTracker DevOps Platform host
- Docker installed
- Managed with Terraform
- Access via AWS Systems Manager Session Manager
EOF